PORT=3000

# MongoDB Atlas primary URI (replace placeholders with your values)
# Example:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/?tls=true&retryWrites=true&w=majority&appName=<app-name>
MONGODB_URI=

# Optional local fallback if Atlas is unreachable
MONGODB_FALLBACK_URI=

# Database name used by the app
MONGODB_DB=hospital_portal
